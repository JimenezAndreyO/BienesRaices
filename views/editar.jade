doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Editar Usuario
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

  body
    .container.mt-5
      h2 Editar Usuario

      form(action=`/Usuarios/editarPersona/${Usuarios.idPersona}` method="POST")
        .mb-3
          label Nombre
          input.form-control(type="text" name="Nombre" value=Usuarios.Nombre required)

        .mb-3
          label Apellido 1
          input.form-control(type="text" name="Apellido1" value=Usuarios.Apellido1 required)

        .mb-3
          label Apellido 2
          input.form-control(type="text" name="Apellido2" value=Usuarios.Apellido2)

        .mb-3
          label Correo
          input.form-control(type="email" name="Correo" value=Usuarios.Correo)

        .mb-3
          label Teléfono
          input.form-control(type="text" name="Telefono" value=Usuarios.Telefono)

        button.btn.btn-primary(type="submit") Actualizar
        a.btn.btn-secondary(href="/usuarios") Volver