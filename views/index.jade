doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Bienes Raíces

    link(
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    )
    link(rel="stylesheet" href="/StyleHome.css")
    script(
      src="https://kit.fontawesome.com/a076d05399.js"
      crossorigin="anonymous"
    )

  body

    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/") BienesRaíces

        button.navbar-toggler(
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        )
          span.navbar-toggler-icon

        .collapse.navbar-collapse#navbarNav
          ul.navbar-nav.ms-auto
            if IdPersona
              li.nav-item
                a.nav-link.text-white(
                  href=NombreRol === 'Administrador' 
                    ? "/Usuarios/InicioAdministrador" 
                    : NombreRol === 'Vendedor'
                      ? "/Usuarios/InicioDeVendedor"
                      : "/Usuarios/InicioPersona"
                )
                  i.fas.fa-home.me-1
                  | Inicio 

              if NombreRol === 'Vendedor'
                li.nav-item
                  a.nav-link.text-white(href="/CompraCasa/CargarBiblioteca")
                    i.fas.fa-book.me-1
                    | Biblioteca 

                li.nav-item
                  a.nav-link.text-white(href="/CompraCasa/CargarCasas")
                    i.fas.fa-home.me-1
                    | Venta de Casas 

              if NombreRol === 'Administrador'
                li.nav-item
                  a.nav-link.text-white(href="/Usuarios/GestionUsuarios")
                    i.fas.fa-users.me-1
                    | Gestión Usuarios

              li.nav-item
                a.nav-link.text-white(href="/Usuarios/CerrarSesion")
                  i.fas.fa-sign-out-alt.me-1
                  | Cerrar sesión
            else
              li.nav-item
                a.nav-link.text-white(href="/")
                  | Inicio

              li.nav-item
                a.nav-link.text-white(href="/Usuarios/Registro")
                  | Login

              li.nav-item
                a.nav-link.text-white(href="/Notas/altatiket")
                  | Contáctanos


    // ================= HERO =================
    .hero
      .hero-overlay
      .container.position-relative.text-center
        h1 Encuentra tu hogar ideal
        p Las mejores propiedades al mejor precio


    // ================= CARRUSEL =================
    if ultimas && ultimas.length > 0
      .container.mt-5
        h2.text-center.mb-4 Últimas propiedades en venta

        #carouselUltimas.carousel.slide(
          data-bs-ride="carousel"
          data-bs-interval="3000"
          data-bs-pause="hover"
        )
          .carousel-inner
            each casa, i in ultimas
              .carousel-item(class=(i === 0 ? "active" : ""))
                if casa.ImagenBase64
                  img.d-block.w-100(
                    src=casa.ImagenBase64
                    style="height:420px; object-fit:cover"
                  )
                else
                  img.d-block.w-100(
                    src="/img/no-image.jpg"
                    style="height:420px; object-fit:cover"
                  )

                .carousel-caption.bg-dark.bg-opacity-50.p-2.rounded
                  h4= casa.Direccion
                  p ₡#{casa.Precio}

          button.carousel-control-prev(
            type="button"
            data-bs-target="#carouselUltimas"
            data-bs-slide="prev"
          )
            span.carousel-control-prev-icon

          button.carousel-control-next(
            type="button"
            data-bs-target="#carouselUltimas"
            data-bs-slide="next"
          )
            span.carousel-control-next-icon


    // ================= TODAS LAS PROPIEDADES =================
    .container.mt-5
      h2.text-center.mb-4 Todas las propiedades

      if casas && casas.length > 0
        .row.row-cols-1.row-cols-md-3.g-4
          each casa in casas
            .col
              .card.shadow-sm
                if casa.ImagenBase64
                  img.card-img-top(
                    src=casa.ImagenBase64
                    alt="Imagen de la casa"
                    style="height:220px; object-fit:cover;"
                  )
                else
                  img.card-img-top(
                    src="/img/no-image.jpg"
                    alt="Sin imagen"
                  )

                .card-body
                  h5.card-title= casa.Direccion
                  p.card-text #{casa.Ciudad}, #{casa.Pais}
                  p.card-text
                    strong Precio:
                    |  ₡#{casa.Precio}

                  a.btn.btn-primary(
                    href=`/CompraCasa/Detalle/${casa.idCasaVenta}`
                  ) Ver más
      else
        p.text-center No hay propiedades en venta por el momento.


    // ================= FOOTER =================
    footer.mt-5.text-center.py-4.bg-dark.text-white
      p.mb-0 © 2025 Bienes Raíces - Todos los derechos reservados


    script(
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
    )
