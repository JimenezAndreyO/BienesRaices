doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Bienes Raíces

    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="/StyleHome.css")
    script(src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous")

  body

    // ========================
    // 🔥 NAVBAR
    // ========================
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="#") BienesRaíces

        button.navbar-toggler(
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        )
          span.navbar-toggler-icon

        .collapse.navbar-collapse#navbarNav
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="#") Inicio
            li.nav-item
              a.nav-link(href="#") Perfil
            li.nav-item
              a.nav-link(href="#") Propiedades
            li.nav-item
              a.nav-link(href="#") Lotes
            li.nav-item
              a.nav-link.text-white.enlace(href="/Notas/altatiket")
                i.fas.fa-info-circle.me-1
                | Contáctanos


    // ========================
    // 🔥 HERO
    // ========================
    .hero
      .hero-overlay
      .container.position-relative.text-center
        h1 Encuentra tu hogar ideal
        p Las mejores propiedades al mejor precio


    // ========================
    // 🔥 EJEMPLO LISTADO PROPIEDADES
    // ========================
    if casas && casas.length > 0
      .container.mt-5
        .row.row-cols-1.row-cols-md-3.g-4
          each casa in casas
            .col
              .card.shadow-sm

                if casa.ImagenBase64
                  img.card-img-top(
                    src=casa.ImagenBase64
                    alt="Imagen de la propiedad"
                    style="height:220px; object-fit:cover;"
                  )
                else
                  img.card-img-top(
                    src="/img/no-image.jpg"
                    alt="Sin imagen"
                    style="height:220px; object-fit:cover;"
                  )

                .card-body
                  h5.card-title= casa.Direccion
                  p.card-text #{casa.Ciudad}, #{casa.Pais}
                  p.card-text
                    strong Precio:
                    |  ₡#{casa.Precio}

    else
      .container.mt-5
        p.text-center No hay propiedades disponibles.


    // ========================
    // 🔥 FOOTER
    // ========================
    footer.mt-5.text-center.py-4.bg-dark.text-white
      p.mb-0 © 2025 Bienes Raíces - Todos los derechos reservados

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
