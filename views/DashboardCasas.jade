doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Gestión de Casas

    // Bootstrap
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")

    // DataTables
    link(rel="stylesheet", href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css")

    script(src="https://code.jquery.com/jquery-3.7.0.min.js")
    script(src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js")

  body
    .container.mt-4
      h2 Gestión de Casas

      if msg == 'eliminado'
        .alert.alert-danger Casa eliminada correctamente

      table#tabla.table.table-striped
        thead
          tr
            th Imagen
            th Dirección
            th País
            th Ciudad
            th Correo
            th Teléfono
            th Precio
            th Estado
            th Acciones

        tbody
          each c in Casas
            tr
              td
                if c.Imagen
                  img(
                    src=c.Imagen
                    alt="Imagen de la casa"
                    style="width:80px; height:60px; object-fit:cover; border-radius:6px;"
                  )
                else
                  span.text-muted Sin imagen

                  
              td= c.Direccion
              td= c.Pais
              td= c.Ciudad
              td= c.CorreoElectronico
              td= c.Telefono
              td= '₡ ' + c.Precio
              td= c.Estado

              td
                a.btn.btn-warning.btn-sm(
                  href=`/CompraCasa/editar/${c.idCasaVenta}`
                ) Editar

                form(
                  action=`/Casas/eliminar/${c.idCasaVenta}`
                  method="POST"
                  style="display:inline;"
                )
                  button.btn.btn-danger.btn-sm(
                    type="submit"
                    onclick="return confirm('¿Eliminar esta casa?')"
                  ) Eliminar

    script.
      $(document).ready(function() {
        $('#tabla').DataTable({
          language: {
            search: "Buscar:",
            lengthMenu: "Mostrar _MENU_ registros",
            info: "Mostrando _START_ a _END_ de _TOTAL_ casas",
            paginate: {
              next: "Siguiente",
              previous: "Anterior"
            }
          }
        });
      });